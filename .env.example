# 智果内网穿透部署示例
# 复制为 .env 后按需修改：cp .env.example .env

# 本机服务
HOST=0.0.0.0
PORT=3300

# 公网访问地址（HTTPS 域名，用于 Android 打包与 Cookie 策略）
# 示例（本机 Cloudflare 隧道）：https://ai.aicreaverse.com
ZHIGUO_PUBLIC_URL=

# HTTPS 穿透时建议开启；若 ZHIGUO_PUBLIC_URL 以 https:// 开头会自动开启
COOKIE_SECURE=

# Paseo 仅本机回环，不要暴露到公网
PASEO_HOME=~/Documents/userinfo/system/paseo
PASEO_LISTEN=127.0.0.1:6767

# 用户数据
ZHIGUO_USERINFO_DIR=~/Documents/userinfo
APP_DATA_DIR=~/Documents/userinfo/system
USER_WORKSPACES_DIR=~/Documents/userinfo/users

# Claude Code
CLAUDE_PATH=claude

# 穿透模式：none | cloudflared-quick | frpc
# - none：已有 Cloudflare 命名隧道 / frp / Nginx 反代（推荐，见 ~/.cloudflared/config.yml）
# - cloudflared-quick：临时 trycloudflare.com（试用）
# - frpc：frp 客户端
TUNNEL_MODE=none

# frpc 配置文件（TUNNEL_MODE=frpc 时使用）
FRPC_CONFIG=deploy/frpc.ini
